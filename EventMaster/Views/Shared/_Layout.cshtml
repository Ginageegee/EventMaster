@using System.Security.Claims
@using Microsoft.AspNetCore.Mvc.TagHelpers

@{
    var isLoggedIn = User?.Identity?.IsAuthenticated ?? false;
    var email = User?.FindFirst(ClaimTypes.Email)?.Value ?? User?.FindFirst("email")?.Value;
    var firstName = User?.FindFirst(ClaimTypes.GivenName)?.Value ?? User?.FindFirst("given_name")?.Value;
    var displayName = !string.IsNullOrWhiteSpace(firstName)
        ? firstName
        : (!string.IsNullOrWhiteSpace(email) ? email : "Account");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventMaster</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventMaster.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 custom-nav">
        <div class="container-fluid">

            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/images/EVENTMASTER_LOGO.png" asp-append-version="true" style="height:40px;" alt="EventMaster Logo" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div id="mainNavbar" class="navbar-collapse collapse d-sm-inline-flex">

                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Events" asp-action="Index">Events</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-sm-center">
                    @if (!isLoggedIn)
                    {
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">
                                <i class="fa-solid fa-arrow-right-to-bracket"></i> Login / Sign Up
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">
                                <i class="fa-solid fa-user"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Logout">
                                <i class="fa-solid fa-right-from-bracket"></i> Logout
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping"></i> Cart
                            </a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - EventMaster - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>