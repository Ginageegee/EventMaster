@model IEnumerable<EventMaster.Models.Venue>

<h2 class="text-white mb-4">Venues</h2>

<a asp-action="AddVenue" class="btn btn-success mb-3">Add Venue</a>

<table class="table table-dark table-bordered">
    <thead>
    <tr>
        <th>Name</th>
        <th>Address</th>
        <th>Capacity</th>
        <th>Phone</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var v in Model)
    {
        <tr>
            <td>@v.Name</td>
            <td>@v.Address</td>
            <td>@v.Capacity</td>
            <td>@v.Phonenumber</td>
            <td>
                <a asp-action="DeleteVenue" asp-route-id="@v.VenueId"
                   class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>