@using Microsoft.AspNetCore.Mvc.TagHelpers
@model EventMaster.Models.Event

<h2>Create Event</h2>

<form asp-action="CreateEvent" asp-controller="Dashboard" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="OrganizerId" />
    <input type="hidden" asp-for="VenueId" />

    <div class="form-group">
        <label asp-for="VenueId">Venue</label>
        <select asp-for="VenueId" class="form-control"
                asp-items="@(new SelectList(ViewBag.Venues, "VenueId", "Name"))">
            <option value="">Select a venue</option>
        </select>
    </div>
    
    <div class="form-group">
        <label asp-for="EventName"></label>
        <input asp-for="EventName" class="form-control"/>
    </div>

    <div class="form-group">
        <label asp-for="EventDescription"></label>
        <textarea asp-for="EventDescription" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label asp-for="EventDate"></label>
        <input asp-for="EventDate" type="date" class="form-control"/>
    </div>

    <div class="form-group">
        <label asp-for="EventTime"></label>
        <input asp-for="EventTime" type="time" class="form-control"/>
    </div>

    <h4 class="mt-4">Ticket Type</h4>

    <div class="form-group">
        <label>Ticket Name</label>
        <input type="text" name="TicketName" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Price</label>
        <input type="number" name="TicketPrice" step="0.01" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Quantity Available</label>
        <input type="number" name="TicketQuantity" class="form-control" required />
    </div>


    <button type="submit" class="btn btn-primary">Create Event</button>
</form>