@using Microsoft.AspNetCore.Mvc.TagHelpers
@model EventMaster.Models.Event

<h2>Create Event</h2>

<form asp-action="CreateEvent" asp-controller="Dashboard" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="OrganizerId" />

    <div class="form-group mb-3">
        <label asp-for="VenueId">Venue</label>
        <select asp-for="VenueId" class="form-control"
                asp-items="@(new SelectList(ViewBag.Venues, "VenueId", "Name"))">
            <option value="">Select a venue</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="EventName"></label>
        <input asp-for="EventName" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="EventDescription"></label>
        <textarea asp-for="EventDescription" class="form-control"></textarea>
    </div>

    <div class="form-group mb-3">
        <label asp-for="EventDate"></label>
        <input asp-for="EventDate" type="date" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="EventTime"></label>
        <input asp-for="EventTime" type="time" class="form-control" />
    </div>

    <hr />

    <h4 class="mt-4">Ticket Types</h4>

    <div id="ticketTypesContainer">
        <div class="ticket-type border p-3 mb-3">
            <div class="form-group mb-2">
                <label>Ticket Name</label>
                <input type="text" name="TicketTypes[0].Name" class="form-control" required />
            </div>

            <div class="form-group mb-2">
                <label>Price</label>
                <input type="number" name="TicketTypes[0].Price" step="0.01" class="form-control" required />
            </div>

            <div class="form-group mb-2">
                <label>Quantity Available</label>
                <input type="number" name="TicketTypes[0].QuantityAvailable" class="form-control" required />
            </div>

            <div class="form-group mb-2">
                <label>Requires Seat?</label>
                <input type="checkbox" name="TicketTypes[0].RequiresSeat" />
            </div>
        </div>
    </div>

    <button type="button" class="btn btn-secondary mb-3" onclick="addTicketType()">Add Another Ticket Type</button>

    <button type="submit" class="btn btn-primary">Create Event</button>
</form>

<script>
    let ticketIndex = 1;

    function addTicketType() {
        const container = document.getElementById('ticketTypesContainer');

        const html = `
            <div class="ticket-type border p-3 mb-3">
                <div class="form-group mb-2">
                    <label>Ticket Name</label>
                    <input type="text" name="TicketTypes[${ticketIndex}].Name" class="form-control" required />
                </div>

                <div class="form-group mb-2">
                    <label>Price</label>
                    <input type="number" name="TicketTypes[${ticketIndex}].Price" step="0.01" class="form-control" required />
                </div>

                <div class="form-group mb-2">
                    <label>Quantity Available</label>
                    <input type="number" name="TicketTypes[${ticketIndex}].QuantityAvailable" class="form-control" required />
                </div>

                <div class="form-group mb-2">
                    <label>Requires Seat?</label>
                    <input type="checkbox" name="TicketTypes[${ticketIndex}].RequiresSeat" />
                </div>

                <button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove()">Remove</button>
            </div>
        `;

        container.insertAdjacentHTML('beforeend', html);
        ticketIndex++;
    }
</script>