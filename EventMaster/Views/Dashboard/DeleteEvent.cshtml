@model EventMaster.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<h2 class="text-white">Delete Event</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">
        @TempData["Error"]
    </div>
}

<div class="alert alert-danger mt-3">
    <strong>Are you sure you want to delete this event?</strong><br />
    This action cannot be undone.
</div>

<div class="card bg-dark text-white mt-4 mb-4 p-3">
    <h4>@Model.EventName</h4>
    <p>@Model.EventDescription</p>

    <p><strong>Date:</strong> @Model.EventDate.ToShortDateString()</p>
    <p><strong>Time:</strong> @Model.EventTime.ToShortTimeString()</p>
    <p><strong>Ticket Types:</strong> @Model.TicketTypes.Count</p>

    <p>
        <strong>Tickets Sold:</strong>
        @Model.Tickets.Count(t => t.OrderId != null)
    </p>

    <p>
        <strong>Total Refund Required:</strong>
        $@ViewBag.TotalRefund
    </p>
</div>

<form asp-action="DeleteEventConfirmed" asp-controller="Dashboard" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.EventId" />
    <input type="hidden" name="expectedRefund" value="@ViewBag.TotalRefund" />

    <div class="alert alert-warning">
        To confirm deletion, type the total refund amount exactly as shown above.
    </div>

    <div class="form-group mb-3">
        <input type="text"
               name="refundConfirmation"
               class="form-control"
               placeholder="Enter refund amount (e.g. 123.45)"
               required />
    </div>

    <button type="submit" class="btn btn-danger me-2">Delete Event</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>