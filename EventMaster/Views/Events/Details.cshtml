@using Microsoft.AspNetCore.Mvc.TagHelpers
@model EventMaster.ViewModels.EventDetailsViewModel

@{
    ViewData["Title"] = Model.Event.EventName;
    var ev = Model.Event;
}

<h2 class="mb-1">@ev.EventName</h2>

<div class="text-muted mb-3">
    @ev.EventDate.ToString("yyyy-MM-dd") @ev.EventTime.ToString("HH:mm")
</div>

@if (!string.IsNullOrWhiteSpace(ev.MediaPath))
{
    @if (ev.MediaType == "image")
    {
        <div class="mb-4">
            <img src="@ev.MediaPath" alt="Event media" class="img-fluid rounded shadow-sm" style="max-height: 500px; width: 100%; object-fit: cover;" />
        </div>
    }
    else if (ev.MediaType == "video")
    {
        <div class="mb-4">
            <video controls class="w-100 rounded shadow-sm" style="max-height: 500px; object-fit: cover;">
                <source src="@ev.MediaPath" />
                Your browser does not support the video tag.
            </video>
        </div>
    }
}

<p>@ev.EventDescription</p>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<hr />
<h4 class="mb-3">Tickets</h4>

@if (Model.TicketTypes == null || Model.TicketTypes.Count == 0)
{
    <p class="text-muted">No ticket types available yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var tt in Model.TicketTypes)
        {
            var available = tt.QuantityAvailable ?? 0;

            <div class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <div class="fw-semibold">@tt.Name</div>
                    <div class="text-muted small">
                        $@tt.Price.ToString("0.00") • @available available
                    </div>
                </div>

                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="TicketTypeId" value="@tt.TicketTypeId" />

                    <input type="number"
                           name="Quantity"
                           value="1"
                           min="1"
                           max="10"
                           class="form-control"
                           style="width:90px"
                           @(available <= 0 ? "disabled" : null) />

                    <button class="btn btn-primary"
                            type="submit"
                            @(available <= 0 ? "disabled" : null)>
                        Add to Cart
                    </button>
                </form>
            </div>
        }
    </div>
}

<div class="mt-4 d-flex gap-2">
    <a asp-controller="Events" asp-action="Index" class="btn btn-link">← Back to events</a>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">View Cart</a>
</div>