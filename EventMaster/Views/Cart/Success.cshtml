@{
    ViewData["Title"] = "Payment Successful";
}

<h2 class="mb-3">Payment successful</h2>

<p class="text-muted">Order #@ViewBag.OrderId</p>

<p>
    Success! Your payment has gone through. We're getting your tickets ready now. 
    You should receive your tickets shortly.
</p>

@if (ViewBag.AmountTotal != null)
{
    <p>
        Amount paid: <strong>$@ViewBag.AmountTotal</strong>
    </p>
}

<div class="mt-3">
    <a asp-controller="Cart" asp-action="MyTickets" class="btn btn-primary">My Tickets</a>
    <a asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary">Back to Events</a>
</div>